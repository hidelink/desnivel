---
import 'leaflet/dist/leaflet.css';
import { t, type Locale } from '../lib/i18n';

interface Props {
  id: string;
  locale: Locale;
  track: [number, number][];
  bounds: { minLat: number; maxLat: number; minLon: number; maxLon: number };
  overrideCenter?: { lat?: number; lon?: number; zoom?: number };
}

const { id, locale, track, bounds, overrideCenter } = Astro.props;
const elId = `route-map-${id}`;
---

<section class="map-block section">
  <div class="wrap">
    <p class="eyebrow">{t(locale, 'map_heading')}</p>
    <div
      id={elId}
      class="map"
      data-track={JSON.stringify(track)}
      data-bounds={JSON.stringify(bounds)}
      data-center={JSON.stringify(overrideCenter ?? {})}
      role="img"
      aria-label={t(locale, 'map_heading')}
    >
      <div class="map-placeholder"></div>
    </div>
  </div>
</section>

<script>
  const ACCENT = '#e8650a';
  // Terrain/contour tiles (not a political/city basemap): remote mountain routes have
  // almost no roads or labels, so a data-viz basemap like CARTO renders as near-solid
  // color there. OpenTopoMap shows real relief/contours everywhere and needs no API key.
  const TILE_URL = 'https://{s}.tile.opentopomap.org/{z}/{x}/{y}.png';
  const ATTRIBUTION =
    'Map data: &copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors, SRTM | Map style: &copy; <a href="https://opentopomap.org">OpenTopoMap</a> (CC-BY-SA)';

  async function initMap(el: HTMLElement) {
    if ((el as any)._initialized) return;
    (el as any)._initialized = true;

    const L = (await import('leaflet')).default;
    const track = JSON.parse(el.dataset.track || '[]') as [number, number][];
    const bounds = JSON.parse(el.dataset.bounds || '{}');
    const center = JSON.parse(el.dataset.center || '{}');

    el.querySelector('.map-placeholder')?.remove();

    const map = L.map(el, { scrollWheelZoom: false });
    L.tileLayer(TILE_URL, {
      attribution: ATTRIBUTION,
      maxZoom: 17,
    }).addTo(map);

    if (track.length > 1) {
      const line = L.polyline(track, { color: ACCENT, weight: 4, opacity: 0.9 }).addTo(map);
      map.fitBounds(line.getBounds(), { padding: [24, 24] });

      const start = track[0];
      const end = track[track.length - 1];
      L.circleMarker(start, { radius: 6, color: '#4fc3f7', weight: 2, fillColor: '#0d0d0d', fillOpacity: 1 }).addTo(
        map
      );
      L.circleMarker(end, { radius: 5, color: '#888', weight: 2, fillColor: '#0d0d0d', fillOpacity: 1 }).addTo(map);
    } else if (bounds.minLat !== undefined) {
      map.fitBounds([
        [bounds.minLat, bounds.minLon],
        [bounds.maxLat, bounds.maxLon],
      ]);
    }

    if (center.zoom) map.setZoom(center.zoom);

    // Leaflet computes its tile grid from the container's size at init time. If web
    // fonts or images above the map are still loading/reflowing, that size can be
    // wrong, leaving tiles positioned off-screen even though they downloaded fine.
    // A ResizeObserver re-triggers layout whenever the container's real size lands.
    const resizeObserver = new ResizeObserver(() => map.invalidateSize());
    resizeObserver.observe(el);
  }

  const observer = new IntersectionObserver(
    (entries) => {
      for (const entry of entries) {
        if (entry.isIntersecting) {
          initMap(entry.target as HTMLElement);
          observer.unobserve(entry.target);
        }
      }
    },
    { rootMargin: '200px' }
  );

  document.querySelectorAll<HTMLElement>('.map').forEach((el) => observer.observe(el));
</script>

<style>
  .map {
    position: relative;
    height: 420px;
    border-radius: var(--radius);
    overflow: hidden;
    border: 1px solid var(--border);
    background: var(--surface);
  }
  .map-placeholder {
    position: absolute;
    inset: 0;
    background: var(--surface);
  }
  @media (max-width: 640px) {
    .map {
      height: 320px;
    }
  }
</style>
