---
import LanguageSwitch from './LanguageSwitch.astro';
import { t, localePath, type Locale } from '../lib/i18n';

interface Props {
  locale: Locale;
  section?: 'home' | 'routes' | 'about';
  esPath?: string;
  enPath?: string;
}

const { locale, section, esPath, enPath } = Astro.props;
---

<header class="site-header">
  <div class="wrap bar">
    <a class="brand" href={localePath(locale, '/')}>
      <img src="/favicon.svg" alt="" width="28" height="28" />
      <span>{t(locale, 'home_title')}</span>
    </a>

    <nav aria-label="Principal">
      <a href={localePath(locale, '/')} aria-current={section === 'home' ? 'page' : undefined}>
        {t(locale, 'nav_home')}
      </a>
      <a href={localePath(locale, '/rutas')} aria-current={section === 'routes' ? 'page' : undefined}>
        {t(locale, 'nav_routes')}
      </a>
      <a href={localePath(locale, '/acerca')} aria-current={section === 'about' ? 'page' : undefined}>
        {t(locale, 'nav_about')}
      </a>
    </nav>

    <div class="tools">
      <LanguageSwitch locale={locale} esPath={esPath} enPath={enPath} />
      <button id="theme-toggle" type="button" aria-label={t(locale, 'theme_toggle')}>
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M8 1v2M8 13v2M1 8h2M13 8h2M3.05 3.05l1.41 1.41M11.54 11.54l1.41 1.41M3.05 12.95l1.41-1.41M11.54 4.46l1.41-1.41"
            stroke="currentColor" stroke-width="1.3" stroke-linecap="round" class="sun-rays"/>
          <circle cx="8" cy="8" r="3.4" stroke="currentColor" stroke-width="1.3" class="sun-core"/>
        </svg>
      </button>
    </div>
  </div>
</header>

<script>
  const KEY = 'desnivel-theme';
  const btn = document.getElementById('theme-toggle');
  btn?.addEventListener('click', () => {
    const root = document.documentElement;
    const current = root.dataset.theme === 'light' ? 'dark' : 'light';
    root.dataset.theme = current;
    localStorage.setItem(KEY, current);
    document.dispatchEvent(new CustomEvent('themechange', { detail: { theme: current } }));
  });
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 40;
    background: var(--overlay);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--border);
  }
  .bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-6);
    height: 64px;
  }
  .brand {
    display: flex;
    align-items: center;
    gap: var(--sp-2);
    text-decoration: none;
    color: var(--text);
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.05rem;
    letter-spacing: 0.02em;
  }
  .brand img {
    border-radius: 6px;
  }
  nav {
    display: flex;
    gap: var(--sp-6);
    font-size: 0.9rem;
  }
  nav a {
    text-decoration: none;
    color: var(--text-muted);
    transition: color 0.15s ease;
  }
  nav a:hover,
  nav a[aria-current='page'] {
    color: var(--text);
  }
  .tools {
    display: flex;
    align-items: center;
    gap: var(--sp-4);
  }
  #theme-toggle {
    background: none;
    border: 1px solid var(--border);
    border-radius: 999px;
    width: 30px;
    height: 30px;
    display: grid;
    place-items: center;
    color: var(--text-muted);
    cursor: pointer;
  }
  #theme-toggle:hover {
    color: var(--accent);
    border-color: var(--accent);
  }
  @media (max-width: 640px) {
    .bar {
      flex-wrap: wrap;
      height: auto;
      padding-block: var(--sp-3);
      row-gap: var(--sp-3);
    }
    nav {
      order: 3;
      width: 100%;
      gap: var(--sp-4);
      font-size: 0.85rem;
    }
  }
</style>
