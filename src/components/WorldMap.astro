---
import 'leaflet/dist/leaflet.css';
import { t, routePath, type Locale } from '../lib/i18n';

interface Pin {
  lat: number;
  lon: number;
  slug: string;
  titulo: string;
  zona: string;
}

interface Props {
  locale: Locale;
  pins: Pin[];
}

const { locale, pins } = Astro.props;
---

<section class="world-map-block section">
  <div class="wrap">
    <p class="eyebrow">{t(locale, 'where_heading')}</p>
    <div
      id="world-map"
      class="map"
      data-pins={JSON.stringify(pins)}
      data-base-href={locale === 'es' ? '' : '/en'}
      role="img"
      aria-label={t(locale, 'where_heading')}
    >
      <div class="map-placeholder"></div>
    </div>
  </div>
</section>

<script>
  const ACCENT = '#e8650a';
  const TILE_URL = 'https://{s}.tile.opentopomap.org/{z}/{x}/{y}.png';
  const ATTRIBUTION =
    'Map data: &copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors, SRTM | Map style: &copy; <a href="https://opentopomap.org">OpenTopoMap</a> (CC-BY-SA)';

  async function initMap(el: HTMLElement) {
    if ((el as any)._initialized) return;
    (el as any)._initialized = true;

    const L = (await import('leaflet')).default;
    const pins = JSON.parse(el.dataset.pins || '[]') as Array<{
      lat: number;
      lon: number;
      slug: string;
      titulo: string;
      zona: string;
    }>;
    const baseHref = el.dataset.baseHref || '';

    el.querySelector('.map-placeholder')?.remove();

    const map = L.map(el, { scrollWheelZoom: false, zoomControl: pins.length > 1 });
    L.tileLayer(TILE_URL, { attribution: ATTRIBUTION, maxZoom: 12 }).addTo(map);

    const markers: any[] = [];
    for (const pin of pins) {
      const icon = L.divIcon({
        className: 'route-pin',
        html: `<span></span>`,
        iconSize: [14, 14],
      });
      const marker = L.marker([pin.lat, pin.lon], { icon }).addTo(map);
      marker.bindTooltip(`${pin.titulo} — ${pin.zona}`, { direction: 'top', offset: [0, -6] });
      marker.on('click', () => {
        window.location.href = `${baseHref}/rutas/${pin.slug}`;
      });
      markers.push(marker);
    }

    if (markers.length > 1) {
      const group = L.featureGroup(markers);
      map.fitBounds(group.getBounds(), { padding: [32, 32] });
    } else if (markers.length === 1) {
      map.setView([pins[0].lat, pins[0].lon], 6);
    } else {
      map.setView([20, 0], 2);
    }

    const resizeObserver = new ResizeObserver(() => map.invalidateSize());
    resizeObserver.observe(el);
  }

  const observer = new IntersectionObserver(
    (entries) => {
      for (const entry of entries) {
        if (entry.isIntersecting) {
          initMap(entry.target as HTMLElement);
          observer.unobserve(entry.target);
        }
      }
    },
    { rootMargin: '200px' }
  );

  document.querySelectorAll<HTMLElement>('#world-map').forEach((el) => observer.observe(el));
</script>

<style is:global>
  .route-pin span {
    display: block;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: #e8650a;
    border: 2px solid #0b0c0c;
    box-shadow: 0 0 0 2px rgba(232, 101, 10, 0.35);
    cursor: pointer;
  }
</style>

<style>
  .world-map-block {
    padding-block: var(--sp-8) var(--sp-12);
  }
  .map {
    position: relative;
    height: 340px;
    border-radius: var(--radius);
    overflow: hidden;
    border: 1px solid var(--border);
    background: var(--surface);
  }
  .map-placeholder {
    position: absolute;
    inset: 0;
    background: var(--surface);
  }
  @media (max-width: 640px) {
    .map {
      height: 260px;
    }
  }
</style>
