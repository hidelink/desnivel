---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import RouteMosaicTile from './RouteMosaicTile.astro';
import { DEFAULT_COVER_IMAGE } from '../lib/media';
import { t, localePath, type Locale } from '../lib/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const entries = await getCollection('rutas', (e) => e.id.startsWith(`${locale}/`) && !e.data.draft);
const routes = [...entries].sort((a, b) => b.data.fecha.getTime() - a.data.fecha.getTime());

const heroImage = routes[0]?.data.gallery[0] ?? DEFAULT_COVER_IMAGE;
const zonas = [...new Set(routes.map((entry) => entry.data.zona))];
---

<BaseLayout
  title={t(locale, 'home_title')}
  description={t(locale, 'home_tagline')}
  locale={locale}
  path={localePath(locale, '/')}
  alternatePath={locale === 'es' ? '/en' : '/'}
  section="home"
  esPath="/"
  enPath="/en"
>
  <section class="hero">
    <div class="wrap grid">
      <div class="text-col">
        <p class="eyebrow">{t(locale, 'home_eyebrow')}</p>
        <h1>{t(locale, 'home_tagline')}</h1>
        <a class="btn-primary" href={localePath(locale, '/rutas')}>{t(locale, 'nav_routes')} →</a>
        {zonas.length > 0 && (
          <div class="zonas">
            <p class="eyebrow">{t(locale, 'where_heading')}</p>
            <ul class="zona-list mono">
              {zonas.map((zona) => <li>{zona}</li>)}
            </ul>
          </div>
        )}
      </div>
      <div class="image-col">
        <img src={heroImage.src} alt={heroImage.alt} loading="eager" />
      </div>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <div class="mosaic">
        {routes.map((entry) => (
          <RouteMosaicTile
            locale={locale}
            slug={entry.data.slug}
            titulo={entry.data.titulo}
            subtitulo={entry.data.subtitulo}
            zona={entry.data.zona}
            tipo={entry.data.tipo}
            distancia_km={entry.data.distancia_km}
            desnivel_m={entry.data.desnivel_m}
            dificultad={entry.data.dificultad}
            coverImage={entry.data.gallery[0]}
          />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    padding-block: var(--sp-12) var(--sp-8);
  }
  .grid {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: var(--sp-12);
    align-items: center;
  }
  .hero h1 {
    margin-top: var(--sp-4);
    max-width: 16ch;
    font-size: clamp(1.8rem, 2.6vw + 1rem, 2.75rem);
  }
  .btn-primary {
    display: inline-block;
    margin-top: var(--sp-8);
    padding: 0.85rem 1.5rem;
    background: var(--lime);
    color: var(--lime-ink);
    text-decoration: none;
    border-radius: var(--radius-pill);
    font-family: var(--font-mono);
    font-size: 0.9rem;
  }
  .zonas {
    margin-top: var(--sp-12);
    padding-top: var(--sp-6);
    border-top: 1px solid var(--border);
  }
  .zona-list {
    margin: var(--sp-3) 0 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
  }
  .zona-list li {
    padding: var(--sp-1) var(--sp-3);
    border: 1px solid var(--border);
    border-radius: var(--radius-pill);
    font-size: 0.75rem;
  }
  .image-col img {
    width: 100%;
    height: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    border-radius: var(--radius);
    border: 1px solid var(--border);
  }
  .mosaic {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--sp-6);
  }
  @media (min-width: 640px) {
    .mosaic {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 1024px) {
    .mosaic {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  @media (max-width: 900px) {
    .grid {
      grid-template-columns: 1fr;
      gap: var(--sp-8);
    }
    .image-col {
      order: -1;
    }
    .image-col img {
      aspect-ratio: 16 / 10;
    }
    .hero h1 {
      max-width: none;
    }
  }
</style>
