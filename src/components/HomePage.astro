---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import WorldMap from './WorldMap.astro';
import RouteMosaicTile from './RouteMosaicTile.astro';
import { loadGpx } from '../lib/gpx';
import { t, localePath, type Locale } from '../lib/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const entries = await getCollection('rutas', (e) => e.id.startsWith(`${locale}/`) && !e.data.draft);
const routes = [...entries].sort((a, b) => b.data.fecha.getTime() - a.data.fecha.getTime());

const pins = routes.map((entry) => {
  const gpx = loadGpx(entry.data.gpx_url);
  return {
    lat: gpx.center[0],
    lon: gpx.center[1],
    slug: entry.data.slug,
    titulo: entry.data.titulo,
    zona: entry.data.zona,
  };
});

---

<BaseLayout
  title={t(locale, 'home_title')}
  description={t(locale, 'home_tagline')}
  locale={locale}
  path={localePath(locale, '/')}
  alternatePath={locale === 'es' ? '/en' : '/'}
  section="home"
  esPath="/"
  enPath="/en"
>
  <section class="hero">
    <div class="contours" aria-hidden="true"></div>
    <div class="wrap">
      <p class="eyebrow">{t(locale, 'home_eyebrow')}</p>
      <h1>{t(locale, 'home_tagline')}</h1>
      <a class="btn-primary" href={localePath(locale, '/rutas')}>{t(locale, 'nav_routes')} →</a>
    </div>
  </section>

  <WorldMap locale={locale} pins={pins} />

  <section class="section">
    <div class="wrap">
      <div class="mosaic">
        {routes.map((entry) => (
          <RouteMosaicTile
            locale={locale}
            slug={entry.data.slug}
            titulo={entry.data.titulo}
            subtitulo={entry.data.subtitulo}
            zona={entry.data.zona}
            tipo={entry.data.tipo}
            distancia_km={entry.data.distancia_km}
            desnivel_m={entry.data.desnivel_m}
            dificultad={entry.data.dificultad}
            coverImage={entry.data.gallery[0]}
          />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    position: relative;
    padding-block: var(--sp-12) var(--sp-8);
    overflow: hidden;
  }
  .contours {
    position: absolute;
    inset: 0;
    z-index: -1;
    opacity: 0.5;
    background-image: repeating-radial-gradient(
      circle at 15% 20%,
      transparent 0,
      transparent 38px,
      var(--border) 39px
    );
    mask-image: linear-gradient(180deg, black, transparent 85%);
  }
  .hero h1 {
    margin-top: var(--sp-4);
    max-width: 20ch;
  }
  .btn-primary {
    display: inline-block;
    margin-top: var(--sp-8);
    padding: 0.85rem 1.5rem;
    background: var(--accent);
    color: #0b0c0c;
    text-decoration: none;
    border-radius: var(--radius);
    font-family: var(--font-mono);
    font-size: 0.9rem;
  }
  .mosaic {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--sp-6);
  }
  @media (min-width: 640px) {
    .mosaic {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 1024px) {
    .mosaic {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
