---
import { translateType, type Locale } from '../lib/i18n';

interface Props {
  locale: Locale;
  titulo: string;
  subtitulo: string;
  tipo: string;
  zona: string;
  ubicacion: string;
  fecha: Date;
  heroImage?: { src: string; alt: string };
}

const { locale, titulo, subtitulo, tipo, zona, ubicacion, fecha, heroImage } = Astro.props;
const dateFmt = new Intl.DateTimeFormat(locale === 'es' ? 'es-MX' : 'en-US', {
  year: 'numeric',
  month: 'long',
});
---

<header class="route-hero">
  <div class="wrap grid">
    <div class="text-col">
      <p class="eyebrow meta">
        <span>{translateType(locale, tipo)}</span>
        <span aria-hidden="true">·</span>
        <span>{zona}</span>
        <span aria-hidden="true">·</span>
        <span>{dateFmt.format(fecha)}</span>
      </p>
      <h1>{titulo}</h1>
      <p class="subtitulo">{subtitulo}</p>
      <p class="ubicacion mono">{ubicacion}</p>
    </div>
    {heroImage && (
      <div class="image-col">
        <img src={heroImage.src} alt={heroImage.alt} loading="eager" />
      </div>
    )}
  </div>
</header>

<style>
  .route-hero {
    padding-block: var(--sp-16) var(--sp-12);
  }
  .grid {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: var(--sp-12);
    align-items: center;
  }
  .image-col img {
    width: 100%;
    height: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    border-radius: var(--radius);
    border: 1px solid var(--border);
  }
  .meta {
    display: flex;
    gap: var(--sp-2);
    margin-bottom: var(--sp-4);
  }
  h1 {
    max-width: 14ch;
  }
  .subtitulo {
    margin-top: var(--sp-4);
    max-width: 40ch;
    font-size: 1.15rem;
    color: var(--text-muted);
  }
  .ubicacion {
    margin-top: var(--sp-6);
    color: var(--accent);
    font-size: 0.85rem;
  }
  @media (max-width: 900px) {
    .grid {
      grid-template-columns: 1fr;
      gap: var(--sp-8);
    }
    .image-col {
      order: -1;
    }
    .image-col img {
      aspect-ratio: 16 / 10;
    }
    h1 {
      max-width: none;
    }
  }
  @media (max-width: 640px) {
    .route-hero {
      padding-block: var(--sp-8) var(--sp-8);
    }
  }
</style>
