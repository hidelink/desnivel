---
import { translateType, type Locale } from '../lib/i18n';

interface Props {
  locale: Locale;
  titulo: string;
  subtitulo: string;
  tipo: string;
  zona: string;
  ubicacion: string;
  fecha: Date;
  heroImage?: { src: string; alt: string };
}

const { locale, titulo, subtitulo, tipo, zona, ubicacion, fecha, heroImage } = Astro.props;
const dateFmt = new Intl.DateTimeFormat(locale === 'es' ? 'es-MX' : 'en-US', {
  year: 'numeric',
  month: 'long',
});
---

<header class="route-hero">
  {heroImage && (
    <div class="hero-image">
      <img src={heroImage.src} alt={heroImage.alt} />
      <div class="hero-scrim"></div>
    </div>
  )}
  <div class="wrap">
    <p class="eyebrow meta">
      <span>{translateType(locale, tipo)}</span>
      <span aria-hidden="true">·</span>
      <span>{zona}</span>
      <span aria-hidden="true">·</span>
      <span>{dateFmt.format(fecha)}</span>
    </p>
    <h1>{titulo}</h1>
    <p class="subtitulo">{subtitulo}</p>
    <p class="ubicacion mono">{ubicacion}</p>
  </div>
</header>

<style>
  .route-hero {
    position: relative;
    padding-block: var(--sp-16) var(--sp-12);
    overflow: hidden;
  }
  .hero-image {
    position: absolute;
    inset: 0;
    z-index: -1;
  }
  .hero-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.55;
  }
  .hero-scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, var(--overlay) 0%, var(--bg) 92%);
  }
  .meta {
    display: flex;
    gap: var(--sp-2);
    margin-bottom: var(--sp-4);
  }
  h1 {
    max-width: 18ch;
  }
  .subtitulo {
    margin-top: var(--sp-4);
    max-width: 48ch;
    font-size: 1.15rem;
    color: var(--text-muted);
  }
  .ubicacion {
    margin-top: var(--sp-6);
    color: var(--accent);
    font-size: 0.85rem;
  }
  @media (max-width: 640px) {
    .route-hero {
      padding-block: var(--sp-8) var(--sp-8);
    }
  }
</style>
