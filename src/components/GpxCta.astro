---
import { t, type Locale } from '../lib/i18n';

interface Props {
  locale: Locale;
  gpx_url: string;
  strava_url?: string;
  tight?: boolean;
}

const { locale, gpx_url, strava_url, tight = false } = Astro.props;
---

<section class={tight ? 'gpx-cta gpx-cta-tight' : 'gpx-cta section'}>
  <div class="wrap actions">
    <a class="btn btn-primary" href={gpx_url} download>
      {t(locale, 'gpx_cta')}
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M7 1v8m0 0L3.5 5.5M7 9l3.5-3.5M1.5 11h11" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </a>
    {strava_url && (
      <a class="btn btn-ghost" href={strava_url} target="_blank" rel="noopener noreferrer">
        {t(locale, 'strava_cta')}
      </a>
    )}
  </div>
</section>

<style>
  .gpx-cta-tight {
    padding-block: 0 var(--sp-8);
  }
  .actions {
    display: flex;
    gap: var(--sp-4);
    flex-wrap: wrap;
  }
  .btn {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    padding: 0.75rem 1.25rem;
    border-radius: var(--radius-pill);
    text-decoration: none;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    letter-spacing: 0.02em;
    border: 1px solid transparent;
    transition: opacity 0.15s ease, border-color 0.15s ease;
  }
  .btn-primary {
    background: var(--lime);
    color: var(--lime-ink);
  }
  .btn-primary:hover {
    opacity: 0.88;
  }
  .btn-ghost {
    border-color: var(--border);
    color: var(--text);
  }
  .btn-ghost:hover {
    border-color: var(--accent);
    color: var(--accent);
  }
</style>
